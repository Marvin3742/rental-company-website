# ─── Copy this file to .env and fill in real values. NEVER commit .env. ─────────

# Neon Postgres. Create a project at https://neon.tech and copy BOTH strings.
#  - DATABASE_URL: the POOLED connection string (has "-pooler" in the host). Used at runtime.
#  - DIRECT_URL:   the DIRECT connection string. Used by `prisma migrate`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Stripe (https://dashboard.stripe.com/apikeys). Use TEST keys for development.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."           # from `stripe listen` or the dashboard webhook
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."   # safe to expose to the browser

# Resend transactional email (https://resend.com). Phase 2+.
RESEND_API_KEY="re_..."
EMAIL_FROM="Solimar Event Rentals <bookings@yourdomain.com>"
OWNER_NOTIFY_EMAIL="SolimarEventRentals88@gmail.com"

# Admin dashboard auth (Phase 4).
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="set-a-strong-password"      # used once to seed the hashed admin user
JWT_SECRET="generate-a-long-random-string"  # signs the admin session cookie

# Vercel Cron protection (optional but recommended): a shared secret the cron route checks.
CRON_SECRET="generate-a-long-random-string"

# Public base URL, used to build Stripe success/cancel redirect URLs.
# Local dev: http://localhost:5173. Vercel Production: https://www.solimareventrentals.com
# (this same origin is the base for the live Stripe webhook: /api/webhooks/stripe).
VITE_SITE_URL="http://localhost:5173"

# Vercel Blob storage — for admin-uploaded product images (compressed to WebP).
# Create a Blob store in the Vercel dashboard (Storage → Create → Blob); it adds
# this automatically in prod. For local dev, copy that token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
